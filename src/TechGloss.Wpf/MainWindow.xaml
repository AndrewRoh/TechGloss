<Window x:Class="TechGloss.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TechGloss" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- 원문 입력 -->
            <DockPanel Grid.Column="0">
                <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,4">
                    <TextBlock Text="원문" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ComboBox DockPanel.Dock="Right" Width="110"
                              ItemsSource="{Binding Directions}"
                              SelectedItem="{Binding SelectedDirection}"/>
                </DockPanel>
                <Button DockPanel.Dock="Bottom" Content="번역 (Ctrl+Enter)" Height="30"
                        Margin="0,4,0,0" Command="{Binding TranslateCommand}"/>
                <TextBox Text="{Binding SourceText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="13"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- 번역 결과 -->
            <DockPanel Grid.Column="2">
                <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,4">
                    <TextBlock Text="번역 결과" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="복사" Width="50"
                            Command="{Binding CopyResultCommand}"/>
                </DockPanel>
                <RichTextBox x:Name="resultRichTextBox"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="13"/>
            </DockPanel>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- 용어 조회 -->
            <DockPanel Grid.Column="4">
                <TextBlock DockPanel.Dock="Top" Text="용어 조회" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox DockPanel.Dock="Top" Margin="0,0,0,4"
                         Text="{Binding LookupQuery, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGrid ItemsSource="{Binding LookupResults}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" FontSize="11">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="EN" Binding="{Binding TermEn}" Width="*"/>
                        <DataGridTextColumn Header="KO" Binding="{Binding TermKo}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <StatusBar Grid.Row="1">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
